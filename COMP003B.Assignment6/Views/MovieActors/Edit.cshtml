@model COMP003B.Assignment6.Models.MovieActor

<h2>Edit Movie Actor</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div>
        <label>Movie</label>
        <select asp-for="MovieId" asp-items="ViewBag.MovieId"></select>
    </div>
    <div>
        <label>Actor</label>
        <select asp-for="ActorId" asp-items="ViewBag.ActorId"></select>
    </div>
    <button type="submit">Save</button>
</form>
<a asp-action="Index">Back to List</a>