@model IEnumerable<COMP003B.Assignment6.Models.Actor>

<h2>Actors</h2>
<p><a asp-action="Create">Create New Actor</a></p>
<table class="table">
    <thead>
    <tr>
        <th>Name</th>
        <th>Nationality</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Nationality</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>